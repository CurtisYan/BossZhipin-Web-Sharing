{
  "manifest_version": 3,
  "name": "BOSS 职位长图分享",
  "description": "在 BOSS 直聘网页端一键生成当前职位的分享长图，支持提取微信扫码分享二维码。",
  "version": "0.3.3",
  "action": {
    "default_title": "生成 BOSS 职位长图",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*",
        "https://*.zhipin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://*.zhipin.com/*",
    "https://img.bosszhipin.com/*",
    "https://img2.bosszhipin.com/*",
    "https://img3.bosszhipin.com/*",
    "https://img4.bosszhipin.com/*",
    "https://*.bosszhipin.com/*"
  ],
  "permissions": ["activeTab", "tabs", "scripting", "clipboardWrite", "storage"]
}
